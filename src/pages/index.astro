---
import Base from '../layouts/Base.astro';
import calculators from '../data/calculators.json';
---
<Base>
  <section class="hero">
    <div class="inner">
      <h1 data-decode>Math you can whiteboard.</h1>
      <p class="pitch">
        Decision calculators for IT infrastructure meetings.
        Enter what you know. Leave with an answer, a whiteboard card,
        a conversation script, and a next action.
      </p>
      <p class="promises mono">
        <span>1.</span> no logins &nbsp; <span>2.</span> no saved data &nbsp; <span>3.</span> no fake precision
      </p>
    </div>
  </section>

  <section class="calc-section">
    <p class="section-label">calculators</p>
    <ul class="calc-list">
      {calculators.map((c) => (
        <li class={`calc-card ${c.status}`}>
          {c.status === 'live' ? (
            <a class="card-link" href={`/${c.slug}`} aria-label={`Open ${c.title}`}>
              <div class="calc-top">
                <span class="calc-index mono">[{c.index}]</span>
                <h2 class="calc-title" data-scramble-hover>{c.title}</h2>
                <span class="badge live-badge">LIVE</span>
              </div>
              <p class="calc-desc">{c.oneLiner}</p>
              <div class="calc-meta">
                <span>{c.inputs} inputs &rarr; {c.outputs} outputs</span>
                <span class="tags">
                  {c.tags.map((t) => <span class="tag">{t}</span>)}
                </span>
              </div>
            </a>
          ) : (
            <>
              <div class="calc-top">
                <span class="calc-index mono">[{c.index}]</span>
                <h2 class="calc-title" data-scramble-hover>{c.title}</h2>
                <span class="badge">QUEUED</span>
              </div>
              <p class="calc-desc">{c.oneLiner}</p>
              <div class="calc-meta">
                <span>{c.inputs} inputs &rarr; {c.outputs} outputs</span>
                <span class="tags">
                  {c.tags.map((t) => <span class="tag">{t}</span>)}
                </span>
              </div>
            </>
          )}
        </li>
      ))}
    </ul>
  </section>

  <section class="about">
    <p class="section-label">what this is</p>
    <ol>
      <li>Decision tools for IT infrastructure meetings, built by a field architect.</li>
      <li>Every calculator returns an answer, a whiteboard card, a script, and a next action.</li>
      <li>Rough math, visible assumptions, formulas public in the source. Never a quote.</li>
    </ol>
  </section>

  <section class="feedback">
    <p class="section-label">feedback</p>
    <form id="feedback-form" autocomplete="off">
      <div class="fb-row">
        <span class="fb-q">Useful?</span>
        <button type="button" class="fb-chip" data-useful="1">yes</button>
        <button type="button" class="fb-chip" data-useful="0">no</button>
      </div>
      <label class="fb-label" for="fb-message">What calculator should exist next, or what is wrong with this one?</label>
      <textarea id="fb-message" maxlength="2000" rows="3"></textarea>
      <div class="fb-row">
        <input id="fb-contact" type="text" maxlength="200" placeholder="contact (optional)">
        <input id="fb-website" type="text" name="website" tabindex="-1" aria-hidden="true" class="fb-hp">
        <button type="submit" class="fb-send">send</button>
      </div>
      <p id="fb-status" class="hint" role="status"></p>
    </form>
  </section>

  <script>
    const form = document.getElementById('feedback-form') as HTMLFormElement;
    const status = document.getElementById('fb-status')!;
    let useful: boolean | null = null;
    form.querySelectorAll<HTMLButtonElement>('.fb-chip').forEach((b) => {
      b.addEventListener('click', () => {
        useful = b.dataset.useful === '1';
        form.querySelectorAll('.fb-chip').forEach((x) => x.classList.toggle('on', x === b));
      });
    });
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const message = (document.getElementById('fb-message') as HTMLTextAreaElement).value.trim();
      if (useful === null && !message) { status.textContent = 'Pick yes or no, or say something.'; return; }
      status.textContent = 'sending...';
      try {
        const r = await fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            calculator: 'landing',
            useful,
            message,
            contact: (document.getElementById('fb-contact') as HTMLInputElement).value.trim(),
            website: (document.getElementById('fb-website') as HTMLInputElement).value,
          }),
        });
        const out = await r.json();
        status.textContent = r.ok && out.ok ? 'Received. Thank you.' : (out.error ?? 'Something broke. Loudly.');
        if (r.ok && out.ok) form.reset();
      } catch {
        status.textContent = 'Network error. The feedback stayed with you.';
      }
    });
  </script>
</Base>
