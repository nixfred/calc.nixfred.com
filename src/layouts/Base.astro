---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'calc.nixfred.com',
  description = 'Field calculators for IT infrastructure conversations. Rough math, honest assumptions, and a next action you can say out loud.',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const shareImageUrl = new URL('/share/card.png', Astro.site).toString();
const shareImageAlt = 'calc.nixfred.com. Math you can whiteboard. Field calculators for IT infrastructure conversations.';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="calc.nixfred.com" />
    <meta property="og:image" content={shareImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={shareImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImageUrl} />
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a class="site-name" href="/">calc.nixfred.com<span class="cursor"></span></a>
        <nav class="site-nav">
          <a href="https://nixfred.com">nixfred.com</a>
          <a href="https://github.com/nixfred/calc.nixfred.com">source</a>
          <button type="button" class="share-btn" data-share-btn>share</button>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="inner">
        <p class="disclaimer">rough math for conversations. never a quote.</p>
        <nav class="footer-links">
          <a href="https://nixfred.com">nixfred.com</a>
          <a href="https://github.com/nixfred/calc.nixfred.com">source on GitHub</a>
        </nav>
        <p class="credit">Built by <a href="https://nixfred.com">Fred Nix</a>. Open source under the MIT license. Fixes and better math welcome by pull request.</p>
      </div>
    </footer>

    <script>
      // Decode/descramble effect: elements with [data-decode] resolve from
      // glyph noise to their real text. Calculator titles re-scramble on hover.
      const GLYPHS = '#$%&@!?*+=<>[]{}/\\|~^;:';
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function decode(el: HTMLElement, duration = 420) {
        const original = el.dataset.text ?? el.textContent ?? '';
        el.dataset.text = original;
        if (reduced || !original.trim()) {
          el.textContent = original;
          return;
        }
        const start = performance.now();
        function frame(now: number) {
          const t = Math.min((now - start) / duration, 1);
          const settled = Math.floor(t * original.length);
          let out = original.slice(0, settled);
          for (let i = settled; i < original.length; i++) {
            const ch = original[i];
            out += ch === ' ' ? ' ' : GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
          }
          el.textContent = out;
          if (t < 1) requestAnimationFrame(frame);
          else el.textContent = original;
        }
        requestAnimationFrame(frame);
      }

      document.querySelectorAll<HTMLElement>('[data-decode]').forEach((el, i) => {
        const original = el.textContent ?? '';
        el.dataset.text = original;
        if (!reduced) {
          el.textContent = original.replace(/\S/g, () => GLYPHS[Math.floor(Math.random() * GLYPHS.length)]);
          setTimeout(() => decode(el), 60 + i * 90);
        }
      });

      document.querySelectorAll<HTMLElement>('[data-scramble-hover]').forEach((el) => {
        el.addEventListener('mouseenter', () => decode(el, 280));
      });

      // Share button: native share sheet where available, clipboard copy
      // otherwise. location.href carries whatever hash or query state the
      // page is in, so a shared link reproduces the current view.
      const shareBtn = document.querySelector<HTMLButtonElement>('[data-share-btn]');
      shareBtn?.addEventListener('click', async () => {
        const description = document.querySelector('meta[name="description"]')?.getAttribute('content') ?? '';
        const url = location.href;
        if (navigator.share) {
          try {
            await navigator.share({ title: document.title, text: description, url });
          } catch (err) {
            if ((err as Error).name !== 'AbortError') console.error('share failed', err);
          }
          return;
        }
        try {
          await navigator.clipboard.writeText(url);
          const original = shareBtn.textContent;
          shareBtn.textContent = 'copied';
          setTimeout(() => { shareBtn.textContent = original; }, 1500);
        } catch (err) {
          console.error('clipboard copy failed', err);
        }
      });
    </script>
    <!-- Cloudflare Web Analytics: cookieless page counts only. Never sees
         entered calculator values (spec 42.3); the audit harness enforces
         that no other external request exists. -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "9996fb7e6e70410893ed26be54810aff"}'></script>
  </body>
</html>
